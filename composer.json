{
    "name": "ck/php-marcspec",
    "type": "library",
    "description": "PHP based MARCspec parser and validator",
    "keywords": [
        "MARCspec",
        "MARC 21"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Carsten Klee",
            "homepage": "http://collidoscope.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "ck/marcspec-test-suite": "@dev"
    },
    "autoload": {
        "psr-4": {
            "CK\\MARCspec\\": "src/",
            "CK\\MARCspec\\Exception\\": "src/Exception/"
        }
    }
}